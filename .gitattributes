# reviewer/validator agent 檔與其真相源由 gen-reviewers.mjs 生成、輸出純 LF；
# 釘 eol=lf 讓 Windows/CI checkout 一致，避免 CRLF/LF 差異讓 --check 在不同平台一綠一紅。
plugins/loops-workflow/agents/*.md text eol=lf
plugins/loops-workflow/references/reviewer-shared.md text eol=lf
plugins/loops-workflow/references/reviewers/*.md text eol=lf
plugins/loops-workflow/scripts/gen-reviewers.mjs text eol=lf
