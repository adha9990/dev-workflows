{
  "description": "loops-workflow hooks：SessionStart 浮出 active 迴圈（resume 輔助）；Stop 記錄估算成本（cost-tracker，opt-in LOOPS_COST_TRACKER，依 API usage 估算、非帳單精確）；PreToolUse(Edit|Write) context 壓力提醒（suggest-compact，opt-in LOOPS_COMPACT_HINT）。兩個 opt-in hook 預設關、永不擋路。",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/cost-tracker.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/suggest-compact.mjs\""
          }
        ]
      }
    ]
  }
}
