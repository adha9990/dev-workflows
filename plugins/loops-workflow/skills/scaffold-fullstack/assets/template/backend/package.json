{
  "name": "@__PROJECT_NAME__/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/bin/server.ts serve --config dev.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/bin/server.js serve --config dev.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ scripts/ e2e/ benchmark/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:benchmark": "vitest run --config vitest.benchmark.config.ts --reporter=verbose",
    "db:migrate:dev": "tsx scripts/db-migrate-dev.ts",
    "db:codegen": "tsx scripts/db-codegen.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^12.2.0",
    "fastify": "^5.8.5",
    "kysely": "^0.27.5",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-import": "^2.32.0",
    "kysely-codegen": "^0.18.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
