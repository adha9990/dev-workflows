{
  "name": "__PROJECT_NAME__",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "description": "Front/back-separated full-stack app — Fastify backend + React SPA (layered architecture)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx src/bin/server.ts serve --config dev.json",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "pnpm build:server && pnpm build:client",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build --config client/vite.config.ts",
    "lint": "eslint src/ scripts/ e2e/ benchmark/ client/",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:benchmark": "vitest run --config vitest.benchmark.config.ts --reporter=verbose",
    "db:migrate:dev": "tsx scripts/db-migrate-dev.ts",
    "db:codegen": "tsx scripts/db-codegen.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@sinclair/typebox": "^0.34.49",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.5",
    "kysely": "^0.27.5",
    "lucide-react": "^1.11.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-plugin": "^1.167.27",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.0",
    "kysely-codegen": "^0.18.5",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
